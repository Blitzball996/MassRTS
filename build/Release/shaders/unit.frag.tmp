#version 330 core
in vec3 v_color;
in vec3 v_normal;
in vec3 v_world_pos;
in float v_part_id;
in vec3 v_local_pos;
in vec3 v_local_normal;

out vec4 frag_color;

const vec3 SKIN = vec3(0.71, 0.53, 0.36);
const vec3 SKIN_DARK = vec3(0.55, 0.40, 0.27);
const vec3 EYE_WHITE = vec3(0.95, 0.95, 0.95);
const vec3 EYE_PUPIL = vec3(0.12, 0.06, 0.40);
const vec3 MOUTH = vec3(0.35, 0.16, 0.12);
const vec3 STEVE_HAIR = vec3(0.22, 0.13, 0.06);
const vec3 STEVE_SHIRT = vec3(0.0, 0.50, 0.50);
const vec3 STEVE_PANTS = vec3(0.16, 0.12, 0.44);
const vec3 STEVE_SHOES = vec3(0.25, 0.22, 0.20);
const vec3 VILLAGER_ROBE = vec3(0.50, 0.32, 0.15);
const vec3 VILLAGER_ROBE_DARK = vec3(0.38, 0.22, 0.10);
const vec3 VILLAGER_COLLAR = vec3(0.82, 0.80, 0.72);
const vec3 SAMURAI_ARMOR = vec3(0.12, 0.12, 0.15);
const vec3 SAMURAI_RED = vec3(0.65, 0.08, 0.05);
const vec3 SAMURAI_GOLD = vec3(0.72, 0.58, 0.15);
const vec3 SHIELD_METAL = vec3(0.55, 0.55, 0.58);
const vec3 SHIELD_WOOD = vec3(0.42, 0.28, 0.12);
const vec3 HELMET_IRON = vec3(0.45, 0.45, 0.50);
const vec3 COW_WHITE = vec3(0.92, 0.88, 0.84);
const vec3 COW_BROWN = vec3(0.30, 0.18, 0.08);
const vec3 IRON = vec3(0.65, 0.68, 0.70);
const vec3 WOOD = vec3(0.45, 0.28, 0.10);
const vec3 STONE = vec3(0.45, 0.42, 0.38);

void main() {
    vec3 n = normalize(v_normal);
    vec3 ln = normalize(v_local_normal); // LOCAL normal for face detection
    int part = int(v_part_id + 0.5);
    bool is_red = v_color.g <= 0.32;

    // Use LOCAL normal for face direction (not affected by Y-rotation)
    bool is_front = (ln.z > 0.8);
    bool is_back = (ln.z < -0.8);
    bool is_top = (ln.y > 0.8);
    bool is_bottom = (ln.y < -0.8);

    vec3 base_color = vec3(0.4);

    if (part == 0) {
        if (is_red) base_color = STEVE_SHIRT;
        else { base_color = VILLAGER_ROBE; if (is_top) base_color = VILLAGER_COLLAR; }
    }
    else if (part == 1) {
        // HEAD - face UV based on local position
        float face_u = (v_local_pos.x + 4.0) / 8.0;
        float face_v = (v_local_pos.y - 24.0) / 8.0;
        if (is_red) {
            if (is_front) {
                base_color = SKIN;
                // Steve face: small friendly eyes like Minecraft
                bool eye_l = (face_u > 0.25 && face_u < 0.37 && face_v > 0.55 && face_v < 0.63);
                bool eye_r = (face_u > 0.63 && face_u < 0.75 && face_v > 0.55 && face_v < 0.63);
                if (eye_l || eye_r) {
                    // Small centered pupils
                    bool pup_l = (face_u > 0.28 && face_u < 0.34 && face_v > 0.56 && face_v < 0.62);
                    bool pup_r = (face_u > 0.66 && face_u < 0.72 && face_v > 0.56 && face_v < 0.62);
                    base_color = (pup_l || pup_r) ? EYE_PUPIL : EYE_WHITE;
                }
                // Small nose
                if (face_u > 0.46 && face_u < 0.54 && face_v > 0.42 && face_v < 0.52) base_color = SKIN_DARK;
                // Thin neutral mouth (not scary)
                if (face_u > 0.38 && face_u < 0.62 && face_v > 0.28 && face_v < 0.33) base_color = MOUTH;
            } else { base_color = STEVE_HAIR; }
        } else {
            if (is_front) {
                base_color = SKIN;
                // Villager: smaller friendly eyes
                bool eye_l = (face_u > 0.24 && face_u < 0.34 && face_v > 0.56 && face_v < 0.63);
                bool eye_r = (face_u > 0.66 && face_u < 0.76 && face_v > 0.56 && face_v < 0.63);
                if (eye_l || eye_r) base_color = vec3(0.10, 0.06, 0.03);
                // Big villager nose
                if (face_u > 0.40 && face_u < 0.60 && face_v > 0.35 && face_v < 0.50) base_color = SKIN_DARK;
            } else if (is_top) { base_color = STEVE_HAIR; }
            else { base_color = SKIN_DARK; }
        }
    }
    else if (part == 2 || part == 3) {
        if (is_red) base_color = mix(STEVE_SHIRT, SKIN, step(0.5, float(is_bottom)));
        else base_color = VILLAGER_ROBE;
    }
    else if (part == 4 || part == 5) {
        if (is_red) { base_color = STEVE_PANTS; if (is_bottom) base_color = STEVE_SHOES; }
        else base_color = VILLAGER_ROBE_DARK;
    }
    else if (part == 6) {
        base_color = IRON;
        if (!is_red && v_local_pos.z > 10.0) base_color = vec3(0.78, 0.78, 0.82);
    }
    else if (part == 7) {
        if (is_red) base_color = HELMET_IRON;
        else { base_color = SAMURAI_ARMOR; if (is_top) base_color = SAMURAI_GOLD; if (v_local_pos.y > 35.0) base_color = SAMURAI_RED; }
    }
    else if (part == 8) {
        float patch = sin(v_local_pos.x * 0.8) * cos(v_local_pos.z * 0.6);
        base_color = mix(COW_WHITE, COW_BROWN, smoothstep(0.1, 0.4, patch));
    }
    else if (part == 9) { base_color = COW_WHITE; if (is_front) base_color = vec3(0.35, 0.30, 0.28); }
    else if (part == 10) { base_color = WOOD; }
    else if (part == 11) {
        base_color = SHIELD_WOOD;
        float band = step(0.6, fract(v_local_pos.y * 0.15));
        base_color = mix(base_color, SHIELD_METAL, band);
        if (length(vec2(v_local_pos.y - 18.0, v_local_pos.z)) < 3.0) base_color = SHIELD_METAL * 1.2;
    }
    else if (part == 12) { base_color = STONE; }

    // Lighting
    vec3 light_dir = normalize(vec3(0.4, 0.85, 0.3));
    float NdotL = max(dot(n, light_dir), 0.0);
    float ambient = 0.45;
    float ao = 1.0;
    if (n.y < -0.5) ao = 0.6;
    else if (abs(n.x) > 0.5) ao = 0.82;
    else if (n.z < -0.5) ao = 0.75;

    vec3 lit = base_color * (ambient + NdotL * 0.55) * ao;

    float dist = length(v_world_pos.xz) / 2500.0;
    lit = mix(lit, vec3(0.55, 0.62, 0.68), clamp(dist * dist * 0.3, 0.0, 0.25));

    frag_color = vec4(lit, 1.0);
}
